#!/usr/bin/env python3

import argparse
import logging
import math
import shutil
import textwrap
from pathlib import Path

from jinja2 import Environment, FileSystemLoader

from lib.config import Config
from lib.package import Package
from lib.pkgloader import PACKAGE_REGISTRY, get_package, load_all_packages
from lib.spec import parse_spec


class Context:
    def __init__(self, config: Config, args: argparse.Namespace):
        self.config = config
        self.args = args

        self.log = logging.getLogger("sd")

        root_dir = Path(__file__).resolve().parent
        self.jinja_env = Environment(
            loader=FileSystemLoader(
                [
                    root_dir / "lib" / "templates",
                    root_dir / "packages",
                ]
            ),
            trim_blocks=True,
            lstrip_blocks=True,
        )

    @property
    def verbose(self) -> bool:
        return getattr(self.args, "verbose", 0) >= 1

    @property
    def debug(self) -> bool:
        return getattr(self.args, "debug", False) or getattr(self.args, "verbose", 0) >= 2


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description="Build and install software packages and containers",
        epilog=textwrap.dedent(
            """\
            Examples:
                # Install default version
                %(prog)s install python

                # Install specific versions
                %(prog)s install gcc@15.2.0 cmake@3.30.9

                # Install a full group
                %(prog)s install --group common

                # Install multiple groups
                %(prog)s install --group common --group sequence_tools

                # Preview installation without executing
                %(prog)s install --group common --dry-run

                # List available packages
                %(prog)s list

                # Filter list by group
                %(prog)s list --group common

                # Inspect package metadata and dependencies
                %(prog)s info python
                %(prog)s info r@4.5.1

                # Regenerate modulefiles for all installed packages
                %(prog)s modules regenerate --all

                # Regenerate modulefiles for specific installed packages
                %(prog)s modules regenerate gcc python@3.14.0

                # Preview modulefile regeneration without writing
                %(prog)s modules regenerate --all --dry-run
            """
        ),
    )

    parser.add_argument(
        "--config",
        default=Path(__file__).with_name("config.toml"),
        type=Path,
        metavar="PATH",
        help="Path to config file",
    )

    subparser = parser.add_subparsers(dest="command", required=True)

    install_parser = subparser.add_parser(
        "install", help="Install one or more packages", description="Install packages and their dependencies"
    )
    install_parser.add_argument(
        "packages",
        nargs="*",
        metavar="package[@version]",
        help="Package(s) to install (e.g. python gcc@15.2.0)",
    )
    install_parser.add_argument(
        "-g",
        "--group",
        action="append",
        metavar="GROUP",
        help="Install a predefined group of packages (e.g. common, sequence_tools)",
    )
    install_parser.add_argument("-f", "--force", action="store_true", help="Force rebuild even if already installed")
    install_parser.add_argument("--dry-run", action="store_true", help="Show the install process without executing")
    install_parser.add_argument(
        "-v", "--verbose", action="count", default=0, help="Increase output verbosity (-v for verbose, -vv for debug)"
    )
    install_parser.add_argument("--debug", action="store_true", help="Enable debug output (same as -vv)")
    install_parser.set_defaults(handler=cmd_install)

    list_parser = subparser.add_parser(
        "list",
        help="List available packages in the registry",
        description="List available packages in the registry",
    )
    list_parser.add_argument(
        "--group", action="append", metavar="GROUP", help="Filter packages by group (e.g. common, sequence_tools)"
    )
    list_parser.set_defaults(handler=cmd_list)

    info_parser = subparser.add_parser(
        "info",
        help="Show package details",
        description="Display metadata about a package including versions, description, and homepage",
    )
    info_parser.add_argument("package", metavar="package[@version]", help="Package to inspect (e.g. r or r@4.5.1)")
    info_parser.set_defaults(handler=cmd_info)

    modules_parser = subparser.add_parser("modules", help="Manage modulefiles", description="Manage modulefiles")

    modules_subparser = modules_parser.add_subparsers(dest="modules_command", required=True)

    modules_regenerate = modules_subparser.add_parser(
        "regenerate",
        help="Regenerate modulefiles for selected packages",
        description="Regenerate modulefiles for selected packages",
    )
    modules_regenerate.add_argument(
        "packages", nargs="*", metavar="package[@version]", help="Package(s) to regenerate modulefiles for"
    )
    modules_regenerate.add_argument(
        "--all", action="store_true", help="Regenerate modulefiles for all installed packages"
    )
    modules_regenerate.add_argument(
        "--dry-run",
        action="store_true",
        help="Show which modulefiles would be regenerated without writing them",
    )
    modules_regenerate.set_defaults(handler=cmd_modules_regenerate)

    args = parser.parse_args()

    if args.command == "install" and not (args.packages or args.group):
        parser.error("install requires at least one package or -g/--group")

    if args.command == "modules" and args.modules_command == "regenerate":
        if not (args.packages or args.all):
            parser.error("modules regenerate requires at least one package or --all")

    return args


def cmd_modules_regenerate(ctx: Context):
    if not PACKAGE_REGISTRY:
        load_all_packages()

    targets = []

    if ctx.args.all:
        for pkg_cls in PACKAGE_REGISTRY.values():
            for version in pkg_cls.versions:
                pkg = pkg_cls(version, ctx)
                if pkg.prefix.exists():
                    targets.append(pkg)

    else:
        for package in ctx.args.packages:
            spec = parse_spec(package)

            pkg_cls = get_package(spec.name)
            pkg = pkg_cls(spec.version, ctx)

            if not pkg.prefix.exists():
                print(f"Skipping {pkg.name}@{pkg.version} (not installed)")
                continue

            targets.append(pkg)

    if not targets:
        print("No installed packages found to regenerate")
        return

    for pkg in targets:
        print(f"==> {pkg.name}@{pkg.version}")

        if ctx.args.dry_run:
            continue

        for dep in pkg.dependencies_spec():
            dep_cls = get_package(dep.name, required_by=pkg.name)
            dep_pkg = dep_cls(dep.version, ctx)

            pkg.dependencies[dep.name] = dep_pkg

        pkg.write_modulefile()

    if ctx.args.dry_run:
        print(f"\nWould regenerate the {len(targets)} modulefile(s) shown above")
    else:
        print(f"\nRegenerated {len(targets)} modulefile(s)")


def build_install_plan(ctx: Context) -> list[Package]:
    plan = []
    seen = set()
    visiting = set()
    stack = []

    def visit(pkg: Package):
        key = (pkg.name, pkg.version)

        if key in visiting:
            start = stack.index(key)
            cycle = stack[start:] + [key]
            chain = " -> ".join(f"{n}@{v}" for n, v in cycle)
            raise ValueError(f"dependency cycle detected: {chain}")

        if key in seen:
            return

        visiting.add(key)
        stack.append(key)

        try:
            for dep in pkg.dependencies_spec():
                dep_cls = get_package(dep.name, required_by=pkg.name)
                dep_pkg = dep_cls(dep.version, ctx)

                pkg.dependencies[dep.name] = dep_pkg

                visit(dep_pkg)

            seen.add(key)
            plan.append(pkg)

        finally:
            stack.pop()
            visiting.remove(key)

    for package in ctx.args.packages:
        spec = parse_spec(package)

        pkg_cls = get_package(spec.name)
        pkg = pkg_cls(spec.version, ctx)

        visit(pkg)

    return plan


def cmd_install(ctx: Context):
    plan = build_install_plan(ctx)

    if ctx.args.dry_run:
        print("Install plan:")
        for pkg in plan:
            print(f"  {pkg.name}@{pkg.version}")
        return

    for pkg in plan:
        pkg.run()


def cmd_list(ctx: Context):
    if not PACKAGE_REGISTRY:
        load_all_packages()

    if not PACKAGE_REGISTRY:
        print("No packages found in the registry.")
        return

    package_names = sorted(PACKAGE_REGISTRY.keys())

    width = shutil.get_terminal_size((80, 20)).columns

    longest_name = max(len(n) for n in package_names) if package_names else 1

    MIN_COL_WIDTH = 20
    padding = 4
    col_width = max(MIN_COL_WIDTH, longest_name + padding)

    cols = max(1, width // col_width)
    rows = math.ceil(len(package_names) / cols)

    grid = []
    for r in range(rows):
        row = []
        for c in range(cols):
            idx = r + c * rows
            if idx < len(package_names):
                row.append(package_names[idx].ljust(col_width))
        grid.append(row)

    for row in grid:
        print("".join(row))


def cmd_info(ctx: Context):
    spec = parse_spec(ctx.args.package)
    pkg_cls = get_package(spec.name)

    INDENT = "    "

    try:
        default_version = pkg_cls.default_version()
    except ValueError:
        default_version = "undefined"

    homepage = pkg_cls.homepage or "(none)"

    description = pkg_cls.description().replace("\n", f"\n{INDENT}")

    versions = "\n".join(f"{INDENT}{v}" for v in pkg_cls.versions) if pkg_cls.versions else f"{INDENT}(none)"

    deps = (
        "\n".join(f"{INDENT}{d.name} [{', '.join(d.types)}]" for d in pkg_cls.dependencies_spec())
        if pkg_cls.dependencies_spec()
        else f"{INDENT}(none)"
    )

    output = f"""\
Package: {spec.name}

Description:
    {description}

Homepage: {homepage}

Default Version:
    {default_version}

Versions:
{versions}

Dependencies:
{deps}
"""

    print(output)


def setup_logging(args: argparse.Namespace):
    verbose = getattr(args, "verbose", 0)
    debug = getattr(args, "debug", False)

    if debug or verbose >= 2:
        level = logging.DEBUG
    elif verbose >= 1:
        level = logging.INFO
    else:
        level = logging.WARNING

    logging.basicConfig(
        level=level,
        format="[%(levelname)s] %(message)s",
        # format="[%(asctime)s] [%(levelname)s] %(message)s",
        # datefmt="%H:%M:%S",
    )


def main():
    args = parse_args()
    config = Config(args.config)

    setup_logging(args)

    ctx = Context(config, args)

    ctx.log.debug("config file = %s", args.config)

    args.handler(ctx)


if __name__ == "__main__":
    main()
