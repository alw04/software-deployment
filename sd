APP_NAME = Path(__file__).stem

log = logging.getLogger(APP_NAME)


def parse_args() -> argparse.Namespace:
    common_opts = argparse.ArgumentParser(add_help=False)
    common_opts.add_argument(
        "-v",
        "--verbose",
        action="count",
        default=0,
        help="Increase output verbosity (-v for verbose, -vv for debug)",
    )
    common_opts.add_argument(
        "--debug",
        action="store_true",
        help="Enable debug output (equivalent to -vv)",
    )

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description="Build and install software packages and containers",
        epilog=textwrap.dedent(
            """\
            Examples:
                # Install default version
                %(prog)s install python

                # Install specific versions
                %(prog)s install gcc@15.2.0 cmake@3.30.9

                # Preview installation without executing
                %(prog)s install repeatmodeler --dry-run

                # Uninstall a package
                %(prog)s uninstall r-ggplot2

                # Uninstall and purge downloads/builds
                %(prog)s uninstall r-ggplot2 --purge

                # List available packages
                %(prog)s list

                # Inspect package metadata and dependencies
                %(prog)s info python
                %(prog)s info r@4.5.1

                # Regenerate modulefiles for all installed packages
                %(prog)s modules regenerate --all

                # Regenerate modulefiles for specific installed packages
                %(prog)s modules regenerate gcc python@3.14.0

                # Preview modulefile regeneration without writing
                %(prog)s modules regenerate --all --dry-run
            """
        ),
    )
    parser.add_argument(
        "--config",
        default=Path(__file__).with_name("config.toml"),
        type=Path,
        metavar="PATH",
        help="Path to config file",
    )

    subparser = parser.add_subparsers(dest="command")

    install_parser = subparser.add_parser(
        "install",
        help="Install one or more packages",
        description="Install packages and their dependencies",
        parents=[common_opts],
    )
    install_parser.add_argument(
        "packages",
        nargs="+",
        metavar="package[@version]",
        help="Package(s) to install (e.g. python gcc@15.2.0)",
    )
    install_parser.add_argument(
        "-f",
        "--force",
        action="count",
        default=0,
        help="Force rebuild of requested packages (-ff also forces dependencies)",
    )
    install_parser.add_argument(
        "--force-deps",
        action="store_true",
        help="Force rebuild of dependencies too (equivalent to -ff)",
    )
    install_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show the install process without executing",
    )
    install_parser.set_defaults(handler=cmd_install)

    uninstall_parser = subparser.add_parser(
        "uninstall",
        help="Uninstall one or more packages",
        description="Remove an installed package's install prefix and modulefile",
        parents=[common_opts],
    )
    uninstall_parser.add_argument(
        "packages",
        nargs="+",
        metavar="package[@version]",
        help="Package(s) to uninstall (e.g. r-ggplot2@4.0.3)",
    )
    uninstall_parser.add_argument(
        "--purge",
        action="store_true",
        help="Also removed cached downloads and build directories for this version",
    )
    uninstall_parser.add_argument(
        "-y",
        "--yes",
        action="store_true",
        help="Don't prompt for confirmation",
    )
    uninstall_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be removed without deleting anything",
    )
    uninstall_parser.set_defaults(handler=cmd_uninstall)

    list_parser = subparser.add_parser(
        "list",
        help="List available packages in the registry",
        description="List available packages in the registry",
        parents=[common_opts],
    )
    list_parser.set_defaults(handler=cmd_list)

    info_parser = subparser.add_parser(
        "info",
        help="Show package details",
        description="Display metadata about a package including versions, description, and homepage",
        parents=[common_opts],
    )
    info_parser.add_argument(
        "package",
        metavar="package[@version]",
        help="Package to inspect (e.g. r or r@4.5.1)",
    )
    info_parser.set_defaults(handler=cmd_info)

    modules_parser = subparser.add_parser(
        "modules",
        help="Manage modulefiles",
        description="Manage modulefiles",
    )

    modules_subparser = modules_parser.add_subparsers(dest="modules_command", required=True)

    modules_regenerate = modules_subparser.add_parser(
        "regenerate",
        help="Regenerate modulefiles for selected packages",
        description="Regenerate modulefiles for selected packages",
        parents=[common_opts],
    )
    modules_regenerate.add_argument(
        "packages",
        nargs="*",
        metavar="package[@version]",
        help="Package(s) to regenerate modulefiles for",
    )
    modules_regenerate.add_argument(
        "--all",
        action="store_true",
        help="Regenerate modulefiles for all installed packages",
    )
    modules_regenerate.add_argument(
        "--dry-run",
        action="store_true",
        help="Show which modulefiles would be regenerated without writing them",
    )
    modules_regenerate.set_defaults(handler=cmd_modules_regenerate)

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        print("\nError: a command is required. See usage above.")
        sys.exit(1)

    if args.command == "modules" and args.modules_command == "regenerate":
        if not (args.packages or args.all):
            parser.error("modules regenerate requires at least one package or --all")

    args.debug = args.debug or args.verbose >= 2

    return args


def cmd_modules_regenerate(ctx: Context):
    load_all_packages()

    targets = []
    seen = set()

    def add_target(pkg: Package):
        key = (pkg.name, pkg.version)

        if key in seen:
            return

        seen.add(key)
        targets.append(pkg)

    if ctx.args.all:
        for pkg_cls in PACKAGE_REGISTRY.values():
            for version in pkg_cls.versions:
                pkg = pkg_cls(version, ctx)

                if not pkg.is_installed:
                    continue

                add_target(pkg)

    else:
        for package in ctx.args.packages:
            spec = parse_spec(package)

            pkg_cls = get_package(spec.name)

            if spec.all_versions:
                found = False

                for version in pkg_cls.versions:
                    pkg = pkg_cls(version, ctx)

                    if not pkg.is_installed:
                        continue

                    found = True
                    add_target(pkg)

                if not found:
                    log.warning(f"No installed versions of {spec.name} found")

            else:
                pkg = pkg_cls(spec.version, ctx)

                if not pkg.is_installed:
                    log.warning(f"Skipping {pkg.name}@{pkg.version} (not installed)")
                    continue

                add_target(pkg)

    if not targets:
        log.warning("No installed packages found to regenerate")
        return

    for pkg in targets:
        print(f"==> {pkg.name}@{pkg.version}")

        if ctx.args.dry_run:
            continue

        for dep in pkg.dependencies_spec():
            dep_cls = get_package(dep.name, required_by=pkg.name)
            dep_pkg = dep_cls(dep.version, ctx)

            pkg.dependencies[dep.name] = dep_pkg

        pkg.write_modulefile()

    if ctx.args.dry_run:
        print(f"\nWould regenerate the {len(targets)} modulefile(s) shown above")
        return

    print(f"\nRegenerated {len(targets)} modulefile(s)")


def build_install_plan(ctx: Context) -> tuple[list[Package], set[tuple[str, str]]]:
    plan = []
    seen = set()
    visiting = set()
    stack = []
    requested_pkgs = set()

    def visit(pkg: Package):
        key = (pkg.name, pkg.version)

        if key in visiting:
            start = stack.index(key)
            cycle = stack[start:] + [key]
            chain = " -> ".join(f"{n}@{v}" for n, v in cycle)
            raise ValueError(f"dependency cycle detected: {chain}")

        if key in seen:
            return

        visiting.add(key)
        stack.append(key)

        try:
            for dep in pkg.dependencies_spec():
                dep_cls = get_package(dep.name, required_by=pkg.name)
                dep_pkg = dep_cls(dep.version, ctx)

                pkg.dependencies[dep.name] = dep_pkg

                visit(dep_pkg)

            seen.add(key)
            plan.append(pkg)

        finally:
            stack.pop()
            visiting.remove(key)

    for package in ctx.args.packages:
        spec = parse_spec(package)
        pkg_cls = get_package(spec.name)

        if spec.all_versions:
            for version in pkg_cls.versions:
                pkg = pkg_cls(version, ctx)
                requested_pkgs.add((pkg.name, pkg.version))
                visit(pkg)
        else:
            pkg = pkg_cls(spec.version, ctx)
            requested_pkgs.add((pkg.name, pkg.version))
            visit(pkg)

    return plan, requested_pkgs


def cmd_install(ctx: Context):
    plan, requested_pkgs = build_install_plan(ctx)

    installed = 0
    skipped = 0

    if ctx.args.dry_run:
        print(f"{'ACTION':<10} {'PACKAGE':<30} {'TYPE'}")
        print(f"{'-'*10} {'-'*30} {'-'*10}")

    for pkg in plan:
        is_requested = (pkg.name, pkg.version) in requested_pkgs
        force_this = (ctx.args.force >= 2 or ctx.args.force_deps) or (ctx.args.force >= 1 and is_requested)
        should_run = not pkg.is_installed or force_this

        if ctx.args.dry_run:
            action = "install" if should_run else "skip"
            pkg_type = "requested" if is_requested else "dependency"
            package = f"{pkg.name}@{pkg.version}"
            print(f"{action:<10} {package:<30} {pkg_type}")

            if should_run:
                installed += 1
            else:
                skipped += 1
            continue

        if not should_run:
            if is_requested:
                print(f"\n==> {pkg.name}@{pkg.version}")
                print("Already installed, skipping (use -f/--force to reinstall)")
                skipped += 1
            continue

        pkg.run()
        installed += 1

    if ctx.args.dry_run:
        print(f"\nWould install {installed} package(s)")
        if skipped:
            print(f"Would skip {skipped} package(s) in the install plan")

            if ctx.args.force == 0 and not ctx.args.force_deps:
                print(
                    "\nUse -f/--force to reinstall requested packages, or -ff/--force-deps to also reinstall dependencies."
                )
        return

    print(f"\nDone: {installed} installed" + (f", {skipped} requested package(s) skipped" if skipped else ""))


def cmd_uninstall(ctx: Context):
    targets = []
    seen = set()

    for package in ctx.args.packages:
        spec = parse_spec(package)
        pkg_cls = get_package(spec.name)

        versions = pkg_cls.versions if spec.all_versions else [spec.version]

        for version in versions:
            pkg = pkg_cls(version, ctx)
            key = (pkg.name, pkg.version)

            if key in seen:
                continue

            seen.add(key)
            targets.append(pkg)

    to_remove = [pkg for pkg in targets if pkg.is_installed]

    for pkg in targets:
        if not pkg.is_installed:
            log.warning("%s@%s is not installed, skipping", pkg.name, pkg.version)

    if not to_remove:
        log.warning("Nothing to uninstall")
        return

    if ctx.args.dry_run:
        print("The following would be removed:")
    else:
        print("The following will be removed:")

    print()

    for pkg in to_remove:
        print(f"{pkg.name}@{pkg.version}")

        paths = [pkg.prefix, pkg.modulefile]
        if ctx.args.purge:
            paths.extend([pkg.download_path, pkg.build_path])

        for path in paths:
            if path.exists():
                print(f"  {path}")

        print()

    if ctx.args.dry_run:
        print(f"Would uninstall {len(to_remove)} package(s)")
        return

    if not ctx.args.yes:
        answer = input("Proceed? [y/N] ").strip().lower()
        if answer not in ("y", "yes"):
            print("Aborted.")
            return

    for pkg in to_remove:
        print(f"Uninstalling {pkg.name}@{pkg.version}")

        if pkg.prefix.exists():
            shutil.rmtree(pkg.prefix)
        pkg.modulefile.unlink(missing_ok=True)

        if ctx.args.purge:
            if pkg.download_path.exists():
                shutil.rmtree(pkg.download_path)
            if pkg.build_path.exists():
                shutil.rmtree(pkg.build_path)

    print(f"\nDone: {len(to_remove)} uninstalled")


def cmd_list(ctx: Context):
    load_all_packages()

    if not PACKAGE_REGISTRY:
        log.warning("No packages found in the registry.")
        return

    package_names = sorted(PACKAGE_REGISTRY.keys())

    if not ctx.term.is_tty:
        for name in package_names:
            print(name)
        return

    longest_name = max(len(n) for n in package_names)

    MIN_COL_WIDTH = 20
    padding = 4
    col_width = max(MIN_COL_WIDTH, longest_name + padding)

    cols = max(1, ctx.term.columns // col_width)
    rows = math.ceil(len(package_names) / cols)

    for r in range(rows):
        row = []
        for c in range(cols):
            idx = r + c * rows
            if idx < len(package_names):
                row.append(package_names[idx].ljust(col_width))
        print("".join(row))


def cmd_info(ctx: Context):
    spec = parse_spec(ctx.args.package)
    pkg_cls = get_package(spec.name)

    term = ctx.term
    INDENT = "    "

    try:
        default_version = pkg_cls.default_version()
    except ValueError:
        default_version = "undefined"

    homepage = pkg_cls.homepage or "(none)"

    description = (pkg_cls.description() or "(none)").replace("\n", f"\n{INDENT}")

    versions = "\n".join(f"{INDENT}{v}" for v in pkg_cls.versions) if pkg_cls.versions else f"{INDENT}(none)"

    deps = (
        "\n".join(f"{INDENT}{d.name} [{', '.join(d.types)}]" for d in pkg_cls.dependencies_spec())
        if pkg_cls.dependencies_spec()
        else f"{INDENT}(none)"
    )

    output = f"""\
{term.cyan}Package:{term.reset} {spec.name}

{term.cyan}Description:{term.reset}
    {description}

{term.cyan}Homepage:{term.reset}
    {homepage}

{term.cyan}Default Version:{term.reset}
    {default_version}

{term.cyan}Versions:{term.reset}
{versions}

{term.cyan}Dependencies:{term.reset}
{deps}
"""

    print(output)


def main():
    args = parse_args()
    term = TermInfo()
    setup_logging(args, term)
    log.debug("loading configuration from %s", args.config.expanduser())

    try:
        xdg = get_xdg_dirs(APP_NAME)
        config = Config(args.config)

        ctx = Context(
            args=args,
            app_root=Path(__file__).resolve().parent,
            xdg=xdg,
            config=config,
            term=term,
        )
        args.handler(ctx)

    except Exception as e:
        if args.debug:
            raise

        log.error("%s", e)
        print("Run with --debug or -vv for full traceback")
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nProgram interrupted by user.")
        sys.exit(130)
